# 分区表：单 app 大分区（factory 3MB，容纳 LVGL）
CONFIG_PARTITION_TABLE_SINGLE_APP_LARGE=y

# LVGL 配置（通过 Kconfig，不使用 lv_conf.h）
CONFIG_LV_COLOR_DEPTH_32=y
CONFIG_LV_USE_OS=1
CONFIG_LV_FONT_MONTSERRAT_14=y
CONFIG_LV_FONT_MONTSERRAT_24=y
CONFIG_LV_FONT_MONTSERRAT_48=y
# 禁用 demo 与日志以减体积
CONFIG_LV_USE_DEMO_WIDGETS=n
CONFIG_LV_USE_DEMO_STRESS=n
CONFIG_LV_USE_DEMO_BENCHMARK=n
CONFIG_LV_USE_DEMO_KEYPAD_ENCODER=n
CONFIG_LV_USE_DEMO_MUSIC=n
CONFIG_LV_USE_LOG=n

# Newlib nano format：printf 栈消耗从 4KB+ 降到几百字节，
# 避免 esp_console / ESP_LOG 在小栈任务里栈溢出（vfprintf 触发 stack protection fault）
CONFIG_LIBC_NEWLIB_NANO_FORMAT=y

# main 任务栈：db_store 人员库加载 + esp-dl 模型加载 + selftest，需要 ≥6KB
CONFIG_ESP_MAIN_TASK_STACK_SIZE=6144

# TWDT：不监控 IDLE 任务。LVGL DIRECT 模式渲染 PSRAM 帧到 framebuffer 时
# 持续占 CPU 不 yield，IDLE 饿死是正常实时系统行为，不应复位。
CONFIG_ESP_TASK_WDT_CHECK_IDLE_TASK_CPU0=n
CONFIG_ESP_TASK_WDT_CHECK_IDLE_TASK_CPU1=n

# Web 后端环境变量示例 — 复制为 .env 并填入实际值
# 部署到云服务器时，broker 指向同机的 EMQX 容器（docker-compose 已注入 MQTT_BROKER=emqx）。

# JWT 密钥（生产环境务必改为随机长串，可用：openssl rand -hex 32）
JWT_SECRET=change-me-to-a-random-long-string
JWT_ALG=HS256
JWT_EXPIRE_HOURS=24

# 默认管理员账号（首次启动写入 SQLite）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# MQTT broker — 云服务器自建 EMQX
# 注意：docker-compose.yml 已用 environment 覆盖为 MQTT_BROKER=emqx（容器间内网通信）。
# 此处值仅在容器外直接运行 uvicorn 时生效。
MQTT_BROKER=127.0.0.1
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_USE_TLS=false

# EMQX Dashboard 管理员（docker-compose 启动 EMQX 用）
EMQX_ADMIN_USER=admin
EMQX_ADMIN_PASS=public

# 订阅的设备 device_id 列表（逗号分隔，留空则订阅所有设备 face_access/+/evt/#）
DEVICE_IDS=

# SQLite 路径
DB_PATH=data/face_access.db

# CORS 允许的前端来源（云服务器用 http://<服务器IP>:8080）
# 部署时改成你的服务器实际 IP
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
